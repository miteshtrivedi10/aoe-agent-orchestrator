{
  "$schema": "https://opencode.ai/config.json",
  "tools": {
    "websearch": false,
    "webfetch": false
  },
  "instructions": [
    "~/.config/opencode/tool-preference.md",
    "~/.config/opencode/git-ban-rules.md",
    "~/.config/opencode/file-deletion-rules.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 8
  },
  "agent": {
    "compaction": {
      "model": "opencode/big-pickle"
    }
  },
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI",
      "options": {
        "baseURL": "https://api.openai.com/v1"
      }
    },
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Anthropic",
      "options": {
        "baseURL": "https://api.anthropic.com/v1"
      }
    },
    "google": {
      "npm": "@ai-sdk/google",
      "name": "Google",
      "options": {
        "baseURL": "https://generativelanguage.googleapis.com/v1beta"
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "openrouter/owl-alpha": {
          "name": "OWL Alpha"
        }
      }
    },
    "castai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cast AI (Kimchi)",
      "options": {
        "baseURL": "https://llm.kimchi.dev/openai/v1"
      },
      "models": {
        "nemotron-3-super-fp4": { "name": "Nemotron 3 Super FP4" },
        "nemotron-3-ultra-fp4": { "name": "Nemotron 3 Ultra FP4" },
        "smollm2-135m": { "name": "SmolLM2 135M" },
        "smollm2-360m": { "name": "SmolLM2 360M" },
        "kimi-k2.5": { "name": "Kimi K2.5" },
        "kimi-k2.6": { "name": "Kimi K2.6" },
        "kimi-k2.7": { "name": "Kimi K2.7" },
        "minimax-m2.5": { "name": "MiniMax M2.5" },
        "minimax-m2.7": { "name": "MiniMax M2.7" },
        "minimax-m3": { "name": "MiniMax M3" },
        "qwen3-coder-next-fp8": { "name": "Qwen3 Coder Next FP8" }
      }
    },
    "zyloo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Zyloo",
      "options": {
        "baseURL": "https://api.zyloo.io/v1"
      }
    },
    "tokenrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "TokenRouter",
      "options": {
        "baseURL": "https://api.tokenrouter.com/v1"
      },
      "models": {
        "MiniMax-M3": { "name": "MiniMax-M3" },
        "DeepSeek V4 Pro": { "name": "deepseek/deepseek-v4-pro" },
        "claude-sonnet-4": { "name": "claude-sonnet-4" }
      }
    }
  },
  "mcp": {},
  "permission": {
    "read": {
      "~/.config/opencode/gsd-core/*": "allow"
    },
    "bash": {
      "git add": "deny",
      "git commit": "deny",
      "git push": "deny"
    },
    "external_directory": {
      "~/.config/opencode/gsd-core/*": "ask"
    }
  }
}
