{
  "$schema": "https://app.kilo.ai/config.json",
  "small_model": "kilo/kilo-auto/free",
  "instructions": [
    ".kilo/rules/*.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 8
  },
  "indexing": {
    "enabled": true,
    "provider": "openai-compatible",
    "gemini": {
      "apiKey": "{env:GEMINI_API_KEY}"
    },
    "embeddingBatchSize": 60,
    "searchMaxResults": 30,
    "scannerMaxBatchRetries": 3,
    "searchMinScore": 0.55,
    "openai-compatible": {
      "baseUrl": "https://api.jina.ai/v1",
      "apiKey": "{env:JINA_API_KEY}"
    },
    "model": "jina-embeddings-v5-text-small",
    "dimension": 1024
  },
  "permission": {
    "webfetch": "deny",
    "websearch": "deny",
    "github_*": "ask",
    "github_get_file_contents": "allow",
    "github_list_commits": "allow",
    "github_list_branches": "allow",
    "github_list_pull_requests": "allow",
    "github_list_issues": "allow",
    "github_create_issue": "allow",
    "github_create_branch": "allow",
    "github_delete_repository": "deny",
    "github_delete_file": "deny",
    "github_delete_issue": "deny",
    "bash": {
      "git push": "ask",
      "git*push": "ask",
      "*": "allow",
      "curl *": "allow",
      "tail *": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "parallel_search": {
      "type": "remote",
      "url": "https://search.parallel.ai/mcp",
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["github-mcp-server"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "enabled": true
    }
  },
  "provider": {
    "OpenRouter": {
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  }
}
